#!/usr/bin/env bash
set -euo pipefail

# Heroku CI's in-dyno Postgres does not bundle pgvector (only real Standard+ add-ons do),
# so db:schema:load would fail on `enable_extension "vector"`. Compile and install pgvector
# from source against the vendored Postgres before the schema loads. pg_config is on PATH
# via the in-dyno buildpack's .profile.d setup. Production already has pgvector — this is
# CI-only.
PGVECTOR_VERSION="${PGVECTOR_VERSION:-v0.8.0}"

PG_CONFIG="$(command -v pg_config)"
if [ -z "${PG_CONFIG}" ]; then
  echo "ci-install-pgvector: pg_config not found on PATH — is the in-dyno Postgres set up?" >&2
  exit 1
fi

if [ -f "$("${PG_CONFIG}" --sharedir)/extension/vector.control" ]; then
  echo "ci-install-pgvector: pgvector already installed, skipping"
  exit 0
fi

echo "ci-install-pgvector: building pgvector ${PGVECTOR_VERSION} against $("${PG_CONFIG}" --version)"
workdir="$(mktemp -d)"
trap 'rm -rf "${workdir}"' EXIT
git clone --quiet --branch "${PGVECTOR_VERSION}" --depth 1 https://github.com/pgvector/pgvector.git "${workdir}"
make -C "${workdir}" PG_CONFIG="${PG_CONFIG}"
make -C "${workdir}" PG_CONFIG="${PG_CONFIG}" install
echo "ci-install-pgvector: installed into $("${PG_CONFIG}" --sharedir)/extension"
