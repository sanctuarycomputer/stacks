<% return unless enterprise.pay_cycle_cadence.present? %>

<h2 style="margin-top: 32px">Pay cycles</h2>
<p style="opacity: 0.7; font-style: italic">Cycles are opened automatically by the cadence background job.</p>

<table border="0" cellspacing="0" cellpadding="0" class="index_table index" style="margin-top: 16px;">
  <thead>
    <tr>
      <th class="col">Period</th>
      <th class="col">Status</th>
      <th class="col">Stub count</th>
      <th class="col">Approved</th>
      <th class="col text-right">Details</th>
    </tr>
  </thead>
  <tbody>
    <% enterprise.pay_cycles.includes(:pay_stubs).order(starts_at: :desc).each_with_index do |pc, index| %>
      <tr class="<%= index.even? ? "even" : "odd" %>">
        <td class="col"><%= pc.starts_at %> – <%= pc.ends_at %></td>
        <td class="col">
          <% case pc.stubs_status
             when :no_stubs %>
            <span class="pill pending">No stubs</span>
          <% when :some_pending %>
            <span class="pill pending">Some pending</span>
          <% when :all_accepted %>
            <span class="pill accepted">All accepted</span>
          <% end %>
        </td>
        <td class="col"><%= pc.pay_stubs.size %></td>
        <td class="col">
          <% if pc.approved? %>
            <span class="pill accepted">Approved</span>
          <% else %>
            <span class="pill pending">Pending</span>
          <% end %>
        </td>
        <td class="col text-right">
          <%= link_to "View ↗", admin_enterprise_pay_cycle_path(enterprise, pc) %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
