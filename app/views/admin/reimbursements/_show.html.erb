<p class="pill nag <%= resource.accepted? ? "accepted" : "pending" %>" style="margin-right: 6px">
  <%= resource.accepted? ? "Accepted" : "Pending" %>
</p>

<p class="pill nag" style="margin-right: 6px">
  <%= number_to_currency(resource.amount) %>
</p>

<%= link_to "Ledger", admin_ledger_path(resource.ledger), class: "nag", style: "margin-right: 6px;" %>

<%= link_to resource.contributor.forecast_person.email, admin_contributor_path(resource.contributor), class: "nag", style: "margin-right: 6px;" %>

<% if resource.qbo_bill.present? %>
  <a href="<%= resource.qbo_bill.qbo_url %>" target="_blank" rel="noopener">
    <p class="nag" style="margin-bottom: 0px;margin-right: 6px;">
      QBO Bill ↗
    </p>
  </a>
  <%# Use the qbo_account-scoped vendor accessor — the bare belongs_to is
      unscoped and can alias across QBO realms when ids collide. %>
  <% vendor = resource.qbo_bill.vendor %>
  <% if vendor.present? %>
    <a href="<%= vendor.qbo_url %>" target="_blank" rel="noopener">
      <p class="nag" style="margin-bottom: 0px;margin-right: 6px;">
        QBO Vendor ↗
      </p>
    </a>
  <% end %>
<% end %>

<div class="dashboard-modules table index_table index" style="margin-top:20px;">
  <div class="dashboard-module">
    <div class="module-header">
      <p>Reimbursement Details</p>
    </div>
    <div class="module-body markdown-body">
      <%= sanitize RDiscount.new(resource.description.to_s).to_html %>
    </div>
  </div>
</div>

<% if resource.receipts.present? %>
  <div class="dashboard-modules table index_table index" style="margin-top:20px;">
    <div class="dashboard-module">
      <div class="module-header">
        <p>Receipts</p>
      </div>
      <div class="module-body markdown-body">
        <%= sanitize RDiscount.new(resource.receipts.to_s).to_html %>
      </div>
    </div>
  </div>
<% end %>
